<Window x:Class="EduSchedule.ReplacementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заменами" Height="550" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель выбора замены -->
        <GroupBox Header="Параметры замены" Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Выберите пару для замены:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbCurrentPair" DisplayMemberPath="Teacher" SelectionChanged="CbPair_Changed"/>

                <TextBlock Text="Причина замены:" Margin="0,10,0,5"/>
                <TextBox x:Name="tbReason" Text="Болезнь преподавателя"/>

                <TextBlock Text="Заменяющий преподаватель:" Margin="0,10,0,5"/>
                <ComboBox x:Name="cbNewTeacher" DisplayMemberPath="Name"/>

                <TextBlock Text="Новая аудитория:" Margin="0,10,0,5"/>
                <ComboBox x:Name="cbNewRoom" DisplayMemberPath="Number"/>

                <Button Content="Проверить доступность" Width="180" Height="30" Margin="0,10,0,0" 
                        Click="BtnCheck_Click" Background="#E0E0E0"/>
                <TextBlock x:Name="lblStatus" Foreground="Gray" Margin="0,5,0,0" FontStyle="Italic"/>
            </StackPanel>
        </GroupBox>

        <!-- Текущее расписание -->
        <DataGrid x:Name="dgSchedule" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" AlternatingRowBackground="#F0F0F0" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="День" Binding="{Binding Day}" Width="60"/>
                <DataGridTextColumn Header="Пара" Binding="{Binding Period}" Width="60"/>
                <DataGridTextColumn Header="Группа" Binding="{Binding Group}" Width="*"/>
                <DataGridTextColumn Header="Дисциплина" Binding="{Binding Discipline}" Width="*"/>
                <DataGridTextColumn Header="Преподаватель" Binding="{Binding Teacher}" Width="*"/>
                <DataGridTextColumn Header="Аудитория" Binding="{Binding Room}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Подтвердить" Width="120" Click="BtnConfirm_Click" Margin="0,0,10,0"/>
            <Button Content="Отмена" Width="100" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>