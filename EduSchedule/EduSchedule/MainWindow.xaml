<Window x:Class="EduSchedule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EduSchedule" Height="450" Width="600"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize">

    <Grid Margin="20">
        <!-- Центральное меню -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Формирование расписания" Width="250" Height="40" Margin="5" Click="BtnSchedule_Click"/>
            <Button Content="Просмотр расписания" Width="250" Height="40" Margin="5" Click="BtnView_Click"/>
            <Button Content="Управление заменами" Width="250" Height="40" Margin="5" Click="BtnReplace_Click"/>
            <Button Content="Справочники" Width="250" Height="40" Margin="5" Click="BtnDict_Click"/>
        </StackPanel>

        <!-- Кнопка выхода -->
        <Button Content="ВЫХОД" Width="100" Height="30" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Margin="0,0,20,20" Click="BtnExit_Click"/>
    </Grid>
</Window>