<Window x:Class="EduSchedule.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EduSchedule — Вход в систему" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="EduSchedule — Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="2" Text="Роль:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbRole" Grid.Row="2" Margin="100,0,0,0">
            <ComboBoxItem Content="Диспетчер / Методист" IsSelected="True"/>
            <ComboBoxItem Content="Заведующий отделением"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Text="Логин:" VerticalAlignment="Center"/>
        <TextBox x:Name="tbLogin" Grid.Row="4" Margin="100,0,0,0"/>

        <TextBlock Grid.Row="6" Text="Пароль:" VerticalAlignment="Center"/>
        <PasswordBox x:Name="pbPassword" Grid.Row="6" Margin="100,0,0,0"/>

        <Button Grid.Row="8" Content="ВОЙТИ" Width="150" Height="35" HorizontalAlignment="Center" Click="BtnLogin_Click"/>
    </Grid>
</Window>