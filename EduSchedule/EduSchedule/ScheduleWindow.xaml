<Window x:Class="EduSchedule.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формирование расписания" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0">
            <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="cbGroup" Width="150" SelectionChanged="CbGroup_SelectionChanged"/>
            <Button Content="Обновить" Margin="10,0,0,0" Width="80" Click="BtnRefresh_Click"/>
        </WrapPanel>

        <DataGrid x:Name="dgSchedule" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F0F0F0" CanUserAddRows="False"/>

        <GroupBox Grid.Row="4" Header="Добавить пару" Padding="10">
            <WrapPanel>
                <TextBox x:Name="tbDiscipline" Width="150" Text="Дисциплина"/>
                <TextBox x:Name="tbTeacher" Width="150" Text="Преподаватель" Margin="5,0,0,0"/>
                <TextBox x:Name="tbRoom" Width="100" Text="201" Margin="5,0,0,0"/>
                <TextBox x:Name="tbDay" Width="40" Text="1" Margin="5,0,0,0" ToolTip="День (1-7)"/>
                <TextBox x:Name="tbPeriod" Width="40" Text="1" Margin="5,0,0,0" ToolTip="Пара (1-6)"/>
                <Button Content="Сохранить" Width="80" Margin="10,0,0,0" Click="BtnSave_Click"/>
            </WrapPanel>
        </GroupBox>
    </Grid>
</Window>